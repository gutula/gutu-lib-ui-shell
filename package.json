{
  "name": "gutu-lib-ui-shell",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/ui-shell build",
    "typecheck": "bun run --cwd framework/libraries/ui-shell typecheck",
    "lint": "bun run --cwd framework/libraries/ui-shell lint",
    "test": "bun run --cwd framework/libraries/ui-shell test",
    "test:unit": "bun run --cwd framework/libraries/ui-shell test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
